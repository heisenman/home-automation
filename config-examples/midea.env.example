# Midea SmartHome cloud account — used ONCE to extract each appliance's local token + key (K1).
# After extraction the token/key are stored locally and control is fully on the LAN (no cloud).
#
# Copy to  instance/midea.env  (gitignored) and fill in real values. NEVER commit credentials.
#   cp config-examples/midea.env.example instance/midea.env  &&  $EDITOR instance/midea.env
#
MIDEA_ACCOUNT=you@example.com
MIDEA_PASSWORD=your-smarthome-app-password
# App account type the device is registered under. Try MSmartHome first (the US "SmartHome" app);
# alternatives the library knows: "NetHome Plus", "Midea Air".
MIDEA_APP=MSmartHome
