# ADR-0016 reconcile tuning — copy to instance/reconcile-tuning.env on each box (gitignored).
# These are the SEED values. The shadow tuner LOGS a `proposed` interval each cycle (to
# /var/log/ha-reconcile-tuning.log) but does NOT apply it while RECONCILE_MODE=shadow — the active
# cadence stays RECONCILE_INTERVAL_S. After ~1 week of shadow data looks sane, flip RECONCILE_MODE=active
# (and/or set RECONCILE_INTERVAL_S from the observed proposed value).

RECONCILE_INTERVAL_S=900     # ACTIVE proactive cadence = fixed 15 min (the loss-at-risk window on sudden death)
RECONCILE_DUTY_PCT=8         # target reconcile duty cycle D/interval (%); interval floor = D*100/PCT
RECONCILE_I_MIN_S=120        # lower clamp — no scp/BLE thrash, never shorter than a reconcile takes
RECONCILE_I_MAX_S=900        # upper clamp = LOSS BUDGET (the one human input) ∧ ≤ hot-tier WINDOW
RECONCILE_MODE=shadow        # shadow = compute+log proposed only | active = drive cadence from proposed
HOT_DB=instance/db/hot.db    # repo-relative or absolute
