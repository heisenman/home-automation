# Instance data — never committed (real MACs, policies, secrets, runtime data)
instance/
venv/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# Editor
.vscode/
.idea/
*.swp
*~

# OS
.DS_Store
Thumbs.db

# Secrets / certs
*.pem
*.key
*.crt
*.p12
ca/

# Logs
*.log

# Imported data dumps & device diagnostics — local only, may carry PII (real MACs,
# location, account names). Root-anchored so tracked source (edge/esp32c6/partitions.csv) stays.
/*.csv
/bugreport-*.zip
/screenshot-*.png
*.btsnoop*
