# Gap watcher secrets — copy to instance/gap-watcher.env (gitignored, chmod 600).
# HA_CMD_SECRET signs the op:history commands the watcher publishes to the edge node — it MUST equal that
# node's per-device secret (the same value baked into its firmware secrets.h and stored in the encrypted
# node_secrets.enc LUT). Broker creds come from instance/mqtt.env.
HA_CMD_SECRET=CHANGE_ME_edge_node_cmd_secret

# Optional overrides (defaults shown):
# HA_GAP_LOOKBACK_DAYS=3      # how far back to scan for gaps (keep within the on-device buffer span)
# HA_GAP_MIN_MIN=20           # a no-reading window longer than this (minutes) counts as a gap
# HA_GAP_SETTLE_S=180         # wait between pulls (one BLE central op at a time)
# HA_EDGE_NODE=c6-bench       # default edge node for inferred routing
