# Weather recorder location — copy to instance/weather.env (gitignored; keeps your
# location out of version control, same as instance/devices.yaml).
#
# Preferred: exact latitude/longitude ("better geolocation")
HA_WEATHER_LAT=0.0
HA_WEATHER_LON=0.0
HA_WEATHER_LABEL=home

# Or, instead of lat/lon, a postal code (geocoded via zippopotam.us):
#HA_WEATHER_ZIP=<YOUR_ZIP>
#HA_WEATHER_COUNTRY=us

# Optional overrides:
#HA_WEATHER_DB=instance/db/weather.db   # separate DB (default) — clean air-gap transfer unit
#HA_WEATHER_INTERVAL=900                 # seconds (used only in continuous mode; timer is 15 min)
