# Per-device-MODEL onboard history-buffer depths — ADR-0016 deferral bound (see ADR-0007, ADR-0009).
#
# These are documented CONSTANTS per device *model*, NOT a per-device retention-policy engine (that
# stays out of scope — nothing evicts per-device on the boxes; parquet is keep-forever). They exist so
# cluster-doctor can turn "device-pull will save us" into a MONITORED bound: a gap older than the
# smallest device buffer can no longer be healed by on-device buffer-pull, so a failover at that point
# relies entirely on the (deferred) parquet cross-box deep-reconcile.
#
#   SwitchBot Meter : undocumented BLE ring buffer, ~68 d of clean recovery (ADR-0007). WRAP-LIMITED —
#                     once the circular buffer wraps, the oldest data is overwritten AND the read
#                     protocol changes (the 02-NAK that already blocks attic/h_bed, ADR-0009). So the
#                     real recoverable depth is "until wrap", and 68 d is the optimistic ceiling.
#   Aranet4         : onboard-log depth = TBD — MEASURE during s3-eth-wired-deploy, then set
#                     BUFFER_ARANET_S below and recompute MIN. It may be SHORTER than SwitchBot and
#                     thus LOWER the binding minimum.

BUFFER_SWITCHBOT_S=5875200        # ~68 d
# BUFFER_ARANET_S=                # TBD: measure Aranet4 onboard-log depth, then set + recompute MIN.

# Minimum across all device models in service = the binding deadline cluster-doctor checks against.
# Until Aranet is measured, use the known SwitchBot figure (NOTE: Aranet may be shorter -> revisit).
MIN_DEVICE_BUFFER_S=5875200
