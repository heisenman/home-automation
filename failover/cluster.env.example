# Per-box cluster identity. Copy to instance/cluster.env on EACH box (gitignored) and edit ROLE/PEER_HOST.
# LAN IPs only (no secrets). The two boxes differ ONLY in ROLE + PEER_HOST.

ROLE=primary                       # primary (210) | standby (245)
PEER_HOST=192.168.0.245            # the OTHER box's real IP
VIP=192.168.0.200                  # floating dictator address (verified free 2026-06-24)
CLUSTER_KEY=/home/visko/.ssh/id_cluster
REMOTE_REPO=/home/visko/home_automation
CONTROLLER_UNIT=ha-controller
API=http://localhost:8123
DEBOUNCE=30                        # seconds the primary must be stably back before standby yields
POLL=5

# 210 (primary) uses: ROLE=primary  PEER_HOST=192.168.0.245
# 245 (standby) uses: ROLE=standby  PEER_HOST=192.168.0.210
